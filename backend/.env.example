#----------------
# Configuration
#----------------
# Rename this file to '.env' and fill in your local/production credentials
# DO NOT commit the actual '.env' file to version control

# -- Database Credentials --
DB_SERVER="localhost,port"
DB_DATABASE=""
DB_USER=""
DB_PASS=""

# -- Environment --
# Set to "development" to enable error display; anything else is treated as production
APP_ENV="development"

# -- Security & Authentication --
# A 6-digit code for development
GLOBAL_OTP="000000"
# Used to sign session cookies and prevent tampering (SHA-256)
HMAC_KEY="generate_secure_key_here"

# -- Azure Blob Storage --
# Connection string from the Azure Portal
AZURE_STORAGE_ACCOUNT_NAME="your_storage_account"
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net"

# -- Email Service (Brevo) --
EMAIL_API_KEY="your_brevo_api_key"
EMAIL_FROM_ADDRESS="verified-sender@example.com"
EMAIL_FROM_NAME="OWP Forum"
EMAIL_SANDBOX="true"
COMMENT_EMAIL_COOLDOWN_MINUTES="10"
